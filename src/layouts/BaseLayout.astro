---
import "../styles/global.css";
import "katex/dist/katex.min.css";
import "highlight.js/styles/github-dark.css";
import { siteConfig } from "../config/site";
import { withBase } from "../lib/paths";

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  path = Astro.url.pathname
} = Astro.props;
const canonicalOrigin = Astro.site?.toString() ?? siteConfig.url;
const canonicalUrl = new URL(path, canonicalOrigin).toString();
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author.name} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href={withBase("/assets/img/favicons/favicon-96x96.png")} sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href={withBase("/assets/img/favicons/favicon.svg")} />
    <link rel="shortcut icon" href={withBase("/assets/img/favicons/favicon.ico")} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase("/assets/img/favicons/apple-touch-icon.png")} />
    <link rel="manifest" href={withBase("/assets/img/favicons/site.webmanifest")} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem("theme");
        if (!t) t = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        if (t === "dark") document.documentElement.setAttribute("data-theme", "dark");
      })();
    </script>
    {
      siteConfig.analytics.goatcounterId && (
        <script
          is:inline
          data-goatcounter={`https://${siteConfig.analytics.goatcounterId}.goatcounter.com/count`}
          async
          src="//gc.zgo.at/count.js"
        ></script>
      )
    }
  </head>
  <body>
    <button class="theme-toggle" aria-label="Toggle dark mode">
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        <a class="footer-author" href={withBase("/")}>{siteConfig.author.name}</a>
        <a
          class="footer-social-link"
          href={siteConfig.social.github}
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
        >
          <img
            class="footer-social-icon"
            src="https://cdn.simpleicons.org/github"
            alt="GitHub"
            loading="lazy"
            decoding="async"
          />
        </a>
        <a
          class="footer-social-link"
          href={siteConfig.social.twitter}
          target="_blank"
          rel="noreferrer"
          aria-label="X"
        >
          <img
            class="footer-social-icon"
            src="https://cdn.simpleicons.org/x"
            alt="X"
            loading="lazy"
            decoding="async"
          />
        </a>
      </p>
      <p class="copyright">© {currentYear} {siteConfig.author.name}. All rights reserved.</p>
    </footer>
    <script is:inline>
      (function() {
        var btn = document.querySelector(".theme-toggle");
        if (!btn) return;
        btn.addEventListener("click", function() {
          var isDark = document.documentElement.getAttribute("data-theme") === "dark";
          if (isDark) {
            document.documentElement.removeAttribute("data-theme");
            localStorage.setItem("theme", "light");
          } else {
            document.documentElement.setAttribute("data-theme", "dark");
            localStorage.setItem("theme", "dark");
          }
        });
      })();
    </script>
  </body>
</html>
