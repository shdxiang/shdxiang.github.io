---
import "../styles/global.css";
import "katex/dist/katex.min.css";
import "highlight.js/styles/github-dark.css";
import { siteConfig } from "../config/site";
import { withBase } from "../lib/paths";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  publishedTime?: string;
  modifiedTime?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  path = Astro.url.pathname,
  ogType = "website",
  ogImage = "/og.png",
  publishedTime,
  modifiedTime,
  jsonLd
} = Astro.props;
const canonicalOrigin = Astro.site?.toString() ?? siteConfig.url;
const canonicalUrl = new URL(path, canonicalOrigin).toString();
const absoluteOgImage = new URL(ogImage, canonicalOrigin).toString();
const currentYear = new Date().getFullYear();
const keywords = siteConfig.keywords?.join(", ");

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.title,
  url: siteConfig.url,
  description: siteConfig.description,
  inLanguage: siteConfig.lang,
  author: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.author.url ?? siteConfig.url
  }
};
const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const allSchemas = [websiteSchema, ...jsonLdArray];
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content={siteConfig.author.name} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:locale" content="zh_CN" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === "article" && (
      <meta property="article:author" content={siteConfig.author.name} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.title} RSS`} href={withBase("/rss.xml")} />
    <link rel="sitemap" type="application/xml" href={withBase("/sitemap-index.xml")} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(allSchemas.length === 1 ? allSchemas[0] : allSchemas)}
    />
    <link rel="icon" type="image/png" href={withBase("/assets/img/favicons/favicon-96x96.png")} sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href={withBase("/assets/img/favicons/favicon.svg")} />
    <link rel="shortcut icon" href={withBase("/assets/img/favicons/favicon.ico")} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase("/assets/img/favicons/apple-touch-icon.png")} />
    <link rel="manifest" href={withBase("/assets/img/favicons/site.webmanifest")} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem("theme");
        if (!t) t = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        if (t === "dark") document.documentElement.setAttribute("data-theme", "dark");
      })();
    </script>
    {
      siteConfig.analytics.goatcounterId && (
        <script
          is:inline
          data-goatcounter={`https://${siteConfig.analytics.goatcounterId}.goatcounter.com/count`}
          async
          src="//gc.zgo.at/count.js"
        ></script>
      )
    }
    <script is:inline async defer src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
    <noscript><img src="https://queue.simpleanalyticscdn.com/noscript.gif" alt="" referrerpolicy="no-referrer-when-downgrade" /></noscript>
  </head>
  <body>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        <a class="footer-author" href={withBase("/")}>{siteConfig.author.name}</a>
        <a
          class="footer-social-link"
          href={siteConfig.social.github}
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
        >
          <img
            class="footer-social-icon"
            src="https://cdn.simpleicons.org/github"
            alt="GitHub"
            loading="lazy"
            decoding="async"
          />
        </a>
        <a
          class="footer-social-link"
          href={siteConfig.social.twitter}
          target="_blank"
          rel="noreferrer"
          aria-label="X"
        >
          <img
            class="footer-social-icon"
            src="https://cdn.simpleicons.org/x"
            alt="X"
            loading="lazy"
            decoding="async"
          />
        </a>
      </p>
      <p class="copyright">© {currentYear} All rights reserved.</p>
    </footer>
    <script is:inline>
      (function() {
        var btn = document.querySelector(".theme-toggle");
        if (!btn) return;
        btn.addEventListener("click", function() {
          var isDark = document.documentElement.getAttribute("data-theme") === "dark";
          if (isDark) {
            document.documentElement.removeAttribute("data-theme");
            localStorage.setItem("theme", "light");
          } else {
            document.documentElement.setAttribute("data-theme", "dark");
            localStorage.setItem("theme", "dark");
          }
        });
      })();
    </script>
  </body>
</html>
