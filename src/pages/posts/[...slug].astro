---
import { getCollection, render } from "astro:content";
import MarkdownRenderer from "../../components/MarkdownRenderer";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../config/site";
import { withBase } from "../../lib/paths";
import { formatDate, getPostHash } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: getPostHash(post) },
    props: { post }
  }));
}

const { post } = Astro.props;
const { headings } = await render(post);
const homePath = withBase("/");
const postUrl = new URL(withBase(`/posts/${getPostHash(post)}/`), siteConfig.url).toString();
const publishedIso = post.data.date.toISOString();
const sameAs = post.data.arxiv_id
  ? [`https://arxiv.org/abs/${post.data.arxiv_id}`]
  : undefined;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description ?? post.data.title,
  datePublished: publishedIso,
  dateModified: publishedIso,
  inLanguage: siteConfig.lang,
  author: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.author.url ?? siteConfig.url
  },
  publisher: {
    "@type": "Organization",
    name: siteConfig.title,
    url: siteConfig.url
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": postUrl },
  url: postUrl,
  ...(sameAs ? { sameAs } : {}),
  ...(post.data.tags ? { keywords: post.data.tags.join(", ") } : {})
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "首页", item: siteConfig.url },
    { "@type": "ListItem", position: 2, name: post.data.title, item: postUrl }
  ]
};
---

<BaseLayout
  title={`${post.data.title} · ${siteConfig.title}`}
  description={post.data.description ?? post.data.title}
  ogType="article"
  publishedTime={publishedIso}
  modifiedTime={publishedIso}
  jsonLd={[blogPostingSchema, breadcrumbSchema]}
>
  <article class="post">
    <header class="post-header">
      <a class="back" href={homePath}>← 返回首页</a>
      <h1>{post.data.title}</h1>
      <p class="meta">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        {post.data.arxiv_id && (
          <a href={`https://arxiv.org/abs/${post.data.arxiv_id}`} target="_blank" rel="noreferrer">
            arXiv: {post.data.arxiv_id}
          </a>
        )}
      </p>
    </header>

    {headings.length > 0 && (
      <aside class="toc">
        <button class="toc-toggle" aria-expanded="false" aria-controls="toc-body">目录</button>
        <strong class="toc-label">目录</strong>
        <div id="toc-body" class="toc-body">
          <ul>
            {headings
              .filter((h) => h.depth <= 3)
              .map((h) => (
                <li class={`d-${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
          </ul>
        </div>
      </aside>
    )}

    <div class="prose">
      <MarkdownRenderer content={post.body ?? ""} />
    </div>
  </article>
  <script is:inline>
    // TOC toggle for mobile
    document.querySelectorAll(".toc-toggle").forEach(function(btn) {
      btn.addEventListener("click", function() {
        var expanded = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!expanded));
        var body = btn.nextElementSibling.nextElementSibling;
        if (body) body.classList.toggle("is-open");
      });
    });

    // Copy code button (with execCommand fallback for non-HTTPS)
    function fallbackCopy(text) {
      var ta = document.createElement("textarea");
      ta.value = text;
      ta.style.cssText = "position:fixed;left:-9999px;top:-9999px;opacity:0";
      document.body.appendChild(ta);
      ta.select();
      try { return document.execCommand("copy"); } catch { return false; }
      finally { document.body.removeChild(ta); }
    }

    document.addEventListener("click", async function(event) {
      var target = event.target;
      if (!(target instanceof Element)) return;
      var button = target.closest(".copy-code-btn");
      if (!(button instanceof HTMLButtonElement)) return;
      var wrapper = button.closest(".code-block");
      var code = wrapper && wrapper.querySelector("pre code");
      if (!(code instanceof HTMLElement)) return;
      var text = code.innerText;
      var ok = false;
      try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
          ok = true;
        } else {
          ok = fallbackCopy(text);
        }
      } catch {
        ok = fallbackCopy(text);
      }
      if (ok) {
        button.classList.remove("is-failed");
        button.classList.add("is-copied");
        button.setAttribute("aria-label", "Copied");
        button.setAttribute("title", "Copied");
      } else {
        button.classList.remove("is-copied");
        button.classList.add("is-failed");
        button.setAttribute("aria-label", "Copy failed");
        button.setAttribute("title", "Copy failed");
      }
      window.setTimeout(function() {
        button.classList.remove("is-copied", "is-failed");
        button.setAttribute("aria-label", "Copy code");
        button.setAttribute("title", "Copy code");
      }, 1200);
    });
  </script>
</BaseLayout>
