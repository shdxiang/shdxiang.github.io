---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import { formatDate, getPostPath } from "../lib/posts";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const featured = posts[0];
const recent = posts.slice(1, 25);
---

<BaseLayout
  title={`${siteConfig.title} | Research Notes`}
  description={siteConfig.description}
>
  <section class="hero">
    <p class="eyebrow">Research Notes</p>
    <h1>Modern Astro-powered blog for fast reading and publishing.</h1>
    <p class="subtitle">内容来自你现有的 `_posts`，发布流程保持 Markdown 驱动。</p>
  </section>

  {
    featured && (
      <a class="featured" href={getPostPath(featured)}>
        <span class="label">Featured</span>
        <h2>{featured.data.title}</h2>
        <p class="meta">
          <time datetime={featured.data.date.toISOString()}>
            {formatDate(featured.data.date)}
          </time>
          {featured.data.arxiv_id && <span>arXiv: {featured.data.arxiv_id}</span>}
        </p>
      </a>
    )
  }

  <section class="grid">
    {recent.map((post) => (
      <a class="card" href={getPostPath(post)}>
        <h3>{post.data.title}</h3>
        <p class="meta">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          {post.data.arxiv_id && <span>arXiv: {post.data.arxiv_id}</span>}
        </p>
      </a>
    ))}
  </section>
</BaseLayout>
