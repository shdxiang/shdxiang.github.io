---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths, Page } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../config/site";
import Pager from "../../components/Pager.astro";
import { formatDate, getPostPath } from "../../lib/posts";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );

  return paginate(posts, { pageSize: 24 });
};

const { page } = Astro.props as { page: Page<CollectionEntry<"posts">> };
---

<BaseLayout
  title={`${siteConfig.title} | 研究笔记 | 第 ${page.currentPage} 页`}
  description={siteConfig.description}
>
  <section class="home-list">
    <section class="grid">
      {page.data.map((post) => (
        <a class="card" href={getPostPath(post)}>
          <h3>{post.data.title}</h3>
          {post.data.description && <p class="card-desc">{post.data.description}</p>}
          <p class="meta">
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            {post.data.arxiv_id && <span>arXiv: {post.data.arxiv_id}</span>}
          </p>
        </a>
      ))}
    </section>
    <Pager
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      prevUrl={page.url.prev ?? undefined}
      nextUrl={page.url.next ?? undefined}
    />
  </section>
</BaseLayout>
